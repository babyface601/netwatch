# ─── NetWatch — Variables d'environnement ─────────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs
# Ne jamais committer le fichier .env sur GitHub

# Authentification (login/logout du dashboard)
NETWATCH_USER=admin
NETWATCH_PASSWORD=changeme

# Clé secrète Flask (sessions) — génère une valeur aléatoire en production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key

# ─── Alertes email (optionnel) ────────────────────────────────────────────────
# Sans ces variables, les alertes apparaissent uniquement dans les logs console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.email@gmail.com
SMTP_PASS=ton_app_password_gmail
ALERT_TO=destinataire@exemple.com

# ─── Mode debug (désactivé par défaut) ───────────────────────────────────────
# FLASK_DEBUG=true
